# Veritype configuration

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Slack (Socket Mode for local dev — no public URL needed)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Veritype runtime
VERITYPE_PORT=3000
VERITYPE_LOG_LEVEL=info

# Optional: limit auto-listen to channels matching this regex
VERITYPE_WATCH_CHANNELS=.*

# Optional: cache directory for rendered verdict cards
VERITYPE_CARD_CACHE_DIR=./runs/cards
