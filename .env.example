# Veritype configuration

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Slack (Socket Mode for local dev — no public URL needed)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Veritype runtime
VERITYPE_PORT=3000
VERITYPE_LOG_LEVEL=info

# Behaviour mode when the bot spots a claim in a watched channel:
#   offer  (default) - post an ephemeral "verify this?" prompt only the speaker sees
#   react            - silently add :eyes: on the message, no verify, no spend
#   auto             - auto-verify above AUTO_THRESHOLD, post card in thread, react with verdict
VERITYPE_MODE=offer

# Claim detection threshold (Haiku screener confidence). Lower = more offers.
VERITYPE_SCREEN_THRESHOLD=0.62

# In `auto` mode only: minimum screener confidence to actually fire a verify.
VERITYPE_AUTO_THRESHOLD=0.75

# In `auto` mode only: max auto-verifications per channel per minute (cost guard).
VERITYPE_AUTO_MAX_PER_MIN=4

# Use custom Veritype reaction emoji (must be uploaded to the workspace first).
# Set to false to fall back to :white_check_mark: / :x: / :warning: / :grey_question:.
VERITYPE_CUSTOM_EMOJI=true

# Optional: limit auto-listen to channels matching this regex
VERITYPE_WATCH_CHANNELS=.*

# Optional: cache directory for rendered verdict cards
VERITYPE_CARD_CACHE_DIR=./runs/cards
